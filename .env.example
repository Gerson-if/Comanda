# Copie este arquivo para ".env" e ajuste os valores.
# Em desenvolvimento, a maioria destas variáveis já tem um default sensato
# (SQLite local) e pode ser deixada em branco.

# --- Ambiente ---
FLASK_ENV=development

# Obrigatório em produção (o app recusa iniciar sem isso). Gere uma com:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao

# --- Banco de dados ---
# Dev (SQLite): pode deixar em branco, cai no default de app/config.py
# Produção (PostgreSQL) — OBRIGATÓRIO, o app recusa iniciar sem isso:
# DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/cardapio_saas
DATABASE_URL=

# --- HTTPS (produção) ---
# Por padrão, o cookie de sessão exige HTTPS (mais seguro). Se você está
# testando em produção SEM HTTPS configurado ainda (ex: direto no IP do
# servidor, sem proxy/certificado), o login vai parecer "não funcionar" —
# nesse caso, defina FORCE_HTTPS=false temporariamente.
# FORCE_HTTPS=true

# --- Rate limiting ---
# Em produção com mais de 1 worker (gunicorn -w N > 1), o limitador em
# memória (padrão) não é compartilhado entre processos — cada worker
# conta separado. Para um limite realmente global, use Redis:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# --- Asaas (cobrança das faturas dos lojistas) ---
# Opcional. Deixe em branco para manter o lançamento manual de fatura
# (já funciona sem isso). Preencha para habilitar geração de cobrança
# real (boleto/Pix/cartão) e liberação automática do lojista quando o
# Asaas confirmar o pagamento via webhook.
#
# ASAAS_API_KEY=            # gerada no painel do Asaas (Integrações → API)
# ASAAS_ENVIRONMENT=sandbox  # "sandbox" (padrão, testes) ou "production"
# ASAAS_WEBHOOK_TOKEN=       # invente uma string aleatória e configure
                              # o MESMO valor no painel do Asaas ao
                              # cadastrar a URL de webhook
