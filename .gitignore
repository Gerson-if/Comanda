__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.env
instance/*.db
app/static/uploads/*
!app/static/uploads/.gitkeep
.pytest_cache/
*.log

# Estado local gerado pelo instalador de deploy (específico de cada servidor)
deploy/.deploy.conf
deploy/backups/*
!deploy/backups/.gitkeep

# Claude Code — estado/config local (pessoal de cada máquina, não compartilhado)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
.claude/routines/.state/
.claude/worktrees/
.claude/checkpoints/
.claude/mailbox/
.claude/agent-registry.json
.claude/agent-memory-local
.claude/first-run
.claude/assistant-daemon-state.json
